RewriteEngine On
RewriteBase /

# 1. Force directory index to open index.html
DirectoryIndex index.html

# 2. Redirect /index.html to /
RewriteCond %{THE_REQUEST} \s/index\.html\s [NC]
RewriteRule ^index\.html$ / [R=301,L]

# 3. Redirect /en/index.html to /en/
RewriteCond %{THE_REQUEST} \s/en/index\.html\s [NC]
RewriteRule ^en/index\.html$ /en/ [R=301,L]

# 4. Redirect /path/to/file.html to /path/to/file
RewriteCond %{THE_REQUEST} \s/+(.+)\.html\s [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# 5. Resolve /path/to/file to /path/to/file.html internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
